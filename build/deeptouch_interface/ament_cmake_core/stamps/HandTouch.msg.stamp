# 手柄状态消息定义
# deeptouch_interface/HandTouch.msg

# 按键状态 (0或1)
uint8 one            # 左手：X按钮，右手：A按钮
uint8 two            # 左手：Y按钮，右手：B按钮  
uint8 three          # 预留按键3
uint8 four           # 预留按键4
uint8 menu           # Menu按钮
uint8 primary_thumb  # 摇杆按下

# 模拟量输入 (0.0-1.0)
float32 hand_trigger   # 握持扳机值
float32 index_trigger  # 食指扳机值

# 摇杆输入 (-1.0到1.0)
float32 thumbstick_x   # 摇杆X轴值
float32 thumbstick_y   # 摇杆Y轴值